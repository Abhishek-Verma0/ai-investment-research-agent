# ─────────────────────────────────────────────────────────────────────────────
# AI Investment Research Agent — environment variables
# Copy this file to `.env` and fill in the values. `.env` is git-ignored.
# All values are validated at server boot (server/src/core/config). Missing or
# malformed required values cause a fast, clear failure.
# ─────────────────────────────────────────────────────────────────────────────

# --- Runtime ---
NODE_ENV=development
# Port the unified Node server listens on (serves API + built client in prod).
PORT=8787

# --- LLM provider ---
# Which LLM provider the agent uses. Default: gemini.
LLM_PROVIDER=gemini
# Google Gemini API key — https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Gemini model id.
GEMINI_MODEL=gemini-3.1-flash-lite

# --- Data providers (free tiers; used by the research tools) ---
# Alpha Vantage (fundamentals; supports US + BSE) — https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=
# Tavily (news / web search with citations) — https://app.tavily.com
TAVILY_API_KEY=

# --- Feature flags (optional subsystems; off by default) ---
# Enable persisted run history (requires DATABASE_URL + Prisma). Off for MVP.
PERSISTENCE_ENABLED=false
# Postgres connection string used only when PERSISTENCE_ENABLED=true.
DATABASE_URL=

# --- Hardening (all optional; sensible defaults) ---
# Abort a single research run if it exceeds this many ms.
RUN_TIMEOUT_MS=120000
# Per-IP rate limit on POST /api/research: max requests per window.
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW_MS=60000

# --- Client ---
# Base URL the client uses to reach the API. Leave blank to use same-origin
# (correct for the unified production deploy). For split local dev the Vite
# proxy handles /api, so this can stay blank.
VITE_API_BASE_URL=
